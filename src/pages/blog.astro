---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import "../styles/blog.css";

const posts = [
  {
    title: "Why Clean Code is a Lie We Tell Seniors.",
    excerpt: "Exploring the pragmatism of 'good enough' code over academic perfection in high-growth startups.",
    image: "/blog_featured_clean_code_1778066687705.png",
    tags: ["CRAFT", "ARCHITECTURE"],
    date: "OCT 12, 2024",
    readTime: "12 MIN READ",
    featured: true
  },
  {
    title: "Mastering the Subgrid: A Guide.",
    excerpt: "Finally, layouts that don't break when your content changes. Dive deep into CSS Subgrid.",
    image: "/blog_subgrid_guide_1778066845930.png",
    tags: ["CSS"],
    date: "OCT 08, 2024",
    readTime: "8 MIN READ"
  },
  {
    title: "The Brutalist UX Manifesto.",
    excerpt: "Why hiding complexity is the biggest mistake you can make in modern UI design.",
    image: "https://placehold.co/600x600/000000/ADFF2F?text=UX+MANIFESTO",
    tags: ["UX DESIGN"],
    date: "OCT 01, 2024",
    readTime: "5 MIN READ"
  },
  {
    title: "Zero-JS Hydration.",
    excerpt: "Stripping the fluff until only the core experience remains. Performance at its rawest.",
    image: "https://placehold.co/600x600/000000/FFD700?text=ZERO-JS",
    tags: ["PERFORMANCE"],
    date: "OCT 22, 2024",
    readTime: "10 MIN READ"
  }
];

const filters = ["ALL", "REACT", "CSS", "UX DESIGN", "PERFORMANCE"];
---

<BaseLayout title="Blog | Insights & Code">
  <main class="flex-grow">
    
    <!-- Hero Section -->
    <section class="blog-hero">
      <div class="container mx-auto px-6">
        <div class="flex flex-col lg:flex-row justify-between items-start gap-12">
          <div class="max-w-3xl">
            <h1 class="font-lexend font-black text-6xl md:text-8xl leading-none tracking-tighter uppercase mb-6">
              CODE <span class="highlight-box">WORDS</span> & IDEAS.
            </h1>
            <p class="font-space font-medium text-xl md:text-2xl max-w-2xl text-gray-700">
              Deep dives into modern web architecture, brutalist UI patterns, and the chaotic beauty of shipping production code. No fluff, just hard logic.
            </p>
          </div>
          
          <!-- Stay Sharp Card -->
          <div class="w-full lg:w-96 border-8 border-black p-10 bg-white shadow-[8px_8px_0px_#000000]">
            <div class="flex items-center gap-3 mb-6">
              <span class="material-symbols-outlined font-black text-3xl">mail</span>
              <h3 class="font-lexend font-black text-3xl uppercase leading-none">STAY SHARP</h3>
            </div>
            <p class="font-space font-medium text-sm text-[#5d5f5f] mb-8 leading-relaxed">
              Get bi-weekly updates on new tutorials and design resources.
            </p>
            <div class="flex flex-col gap-4">
              <input 
                type="email" 
                placeholder="YOUR_EMAIL@DEV.COM" 
                class="bg-white border-4 border-black p-4 h-14 font-medium text-base text-black focus:outline-none focus:shadow-[4px_4px_0px_#000000] transition-all placeholder:text-gray-400"
              />
              <Button variant="green" size="lg" class="w-full">
                <span class="font-lexend font-black uppercase tracking-wider">SUBSCRIBE NOW</span>
              </Button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Caution Divider -->
    <div class="caution-divider"></div>

    <!-- Content Section -->
    <div class="container mx-auto px-6 py-12">
      
      <!-- Pinned Post Multi-Gallery Section -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
        <div class="md:col-span-3">
          <div class="flex flex-col md:flex-row gap-8 items-start">
            
            <!-- Column 1: Main Article Stage (The Display) -->
            <div id="pinned-stage" class="blog-card bg-white border-8 border-black p-0 shadow-[12px_12px_0px_#000000] flex-grow md:w-[78%] overflow-hidden transition-all duration-300">
              <div class="flex flex-col lg:flex-row h-full">
                <!-- Image Side -->
                <div class="lg:w-1/2 relative overflow-hidden h-80 lg:h-auto lg:min-h-[500px] border-b-8 lg:border-b-0 lg:border-r-8 border-black bg-gray-100">
                  <div class="absolute top-4 left-4 z-20 bg-[#ADFF2F] border-4 border-black px-3 py-1 font-black text-[10px] uppercase shadow-[4px_4px_0px_#000000]">
                    📌 PINNED
                  </div>
                  <img id="stage-img" src={posts[0].image} class="w-full h-full object-cover" alt="Featured" />
                </div>
                
                <!-- Content Side -->
                <div class="lg:w-1/2 p-8 md:p-12 flex flex-col justify-center">
                  <div class="flex items-center gap-2 mb-6" id="stage-tags">
                    {posts[0].tags.map(tag => <span class="blog-tag tag-green">{tag}</span>)}
                  </div>
                  <h2 id="stage-title" class="font-lexend font-black text-3xl md:text-5xl uppercase leading-[0.9] tracking-tighter mb-6">
                    {posts[0].title}
                  </h2>
                  <p id="stage-excerpt" class="font-space font-medium text-lg text-gray-700 leading-relaxed mb-8">
                    {posts[0].excerpt}
                  </p>
                  <div class="mt-auto pt-8 border-t-4 border-black flex justify-between items-center">
                    <div class="flex flex-col">
                      <span id="stage-date" class="font-black text-sm">{posts[0].date}</span>
                      <span id="stage-read" class="font-black text-xs text-gray-400">{posts[0].readTime}</span>
                    </div>
                    <Button variant="green" size="md">
                      <span class="font-black italic">OPEN STORY</span>
                    </Button>
                  </div>
                </div>
              </div>
            </div>

            <!-- Column 2: Article Switcher Gallery (Thumbnails) -->
            <div class="md:w-[22%] w-full">
              <div class="flex flex-col gap-4">
                <span class="font-lexend font-black text-xs uppercase italic border-b-4 border-black pb-2 mb-2">Editor's Pinned List</span>
                <div class="flex flex-row md:flex-col gap-4 overflow-x-auto md:overflow-y-visible pb-4 md:pb-0">
                  {posts.map((post, i) => (
                    <button 
                      class="article-switcher-btn group flex flex-col w-32 md:w-full flex-shrink-0 border-4 border-black bg-white shadow-[4px_4px_0px_#000000] hover:shadow-[6px_6px_0px_#ADFF2F] transition-all text-left"
                      data-title={post.title}
                      data-excerpt={post.excerpt}
                      data-image={post.image}
                      data-date={post.date}
                      data-read={post.readTime}
                      data-tags={JSON.stringify(post.tags)}
                    >
                      <div class="h-20 md:h-24 w-full overflow-hidden border-b-4 border-black">
                        <img src={post.image} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt={post.title} />
                      </div>
                      <div class="p-3">
                        <h4 class="font-lexend font-black text-[10px] leading-tight uppercase line-clamp-2">{post.title}</h4>
                      </div>
                    </button>
                  ))}
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <script>
        const switchBtns = document.querySelectorAll('.article-switcher-btn');
        const stageImg = document.getElementById('stage-img') as HTMLImageElement;
        const stageTitle = document.getElementById('stage-title');
        const stageExcerpt = document.getElementById('stage-excerpt');
        const stageDate = document.getElementById('stage-date');
        const stageRead = document.getElementById('stage-read');
        const stageTags = document.getElementById('stage-tags');

        switchBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const data = {
              title: btn.getAttribute('data-title'),
              excerpt: btn.getAttribute('data-excerpt'),
              image: btn.getAttribute('data-image'),
              date: btn.getAttribute('data-date'),
              read: btn.getAttribute('data-read'),
              tags: JSON.parse(btn.getAttribute('data-tags') || '[]')
            };

            const stage = document.getElementById('pinned-stage');
            if (stage) stage.style.opacity = '0.7';

            setTimeout(() => {
              if (stageImg) stageImg.src = data.image || '';
              if (stageTitle) stageTitle.innerText = data.title || '';
              if (stageExcerpt) stageExcerpt.innerText = data.excerpt || '';
              if (stageDate) stageDate.innerText = data.date || '';
              if (stageRead) stageRead.innerText = data.read || '';
              
              if (stageTags) {
                stageTags.innerHTML = data.tags.map((tag: string) => 
                  `<span class="blog-tag tag-green">${tag}</span>`
                ).join('');
              }

              if (stage) stage.style.opacity = '1';
            }, 150);
          });
        });
      </script>

      <!-- Filters Section -->
      <div class="flex flex-wrap items-center justify-between gap-8 mb-12 border-b-8 border-black pb-10">
        <!-- Category Tabs (Button Style) -->
        <div class="flex flex-wrap gap-4">
          <button class="filter-btn-neo active">ALL POSTS</button>
          <button class="filter-btn-neo">UX DESIGN</button>
          <button class="filter-btn-neo">DEVELOPMENT</button>
          <button class="filter-btn-neo">CRAFT</button>
        </div>

        <!-- Mini Custom Dropdown (Sort By) -->
        <div class="flex items-center gap-4">
          <span class="font-lexend font-black uppercase text-xs text-gray-500 italic">Sort by:</span>
          <div class="relative w-44" id="sort-container">
            <button id="sort-button" class="mini-dropdown-btn">
              <span id="sort-selected-value">LATEST</span>
              <div class="mini-arrow-wrapper">
                <svg id="sort-arrow" class="w-4 h-4 transition-transform" viewBox="0 0 24 24" fill="none">
                  <path d="M6 9L12 15L18 9" stroke="black" stroke-width="4" stroke-linecap="square"/>
                </svg>
              </div>
            </button>
            
            <div id="sort-options" class="hidden absolute top-full left-0 w-full bg-white border-4 border-black shadow-[6px_6px_0px_#000000] z-50 mt-2">
              <div class="sort-option active" data-value="LATEST">LATEST</div>
              <div class="sort-option" data-value="OLDEST">OLDEST</div>
              <div class="sort-option" data-value="MOST READ">MOST READ</div>
            </div>
          </div>
        </div>
      </div>

      <style>
        /* Category Buttons */
        .filter-btn-neo {
          padding: 10px 20px;
          background: white;
          border: 4px solid black;
          font-family: 'Lexend', sans-serif;
          font-weight: 900;
          text-transform: uppercase;
          font-size: 13px;
          box-shadow: 4px 4px 0px #000000;
          transition: all 0.2s ease;
          cursor: pointer;
        }
        .filter-btn-neo:hover {
          transform: translate(-2px, -2px);
          box-shadow: 6px 6px 0px #000000;
        }
        .filter-btn-neo.active {
          background: #ADFF2F;
          box-shadow: none;
          transform: translate(4px, 4px);
        }

        /* Mini Dropdown */
        .mini-dropdown-btn {
          width: 100%;
          background: white;
          border: 4px solid black;
          height: 44px;
          padding: 0 44px 0 16px;
          font-weight: 900;
          font-size: 12px;
          text-transform: uppercase;
          display: flex;
          align-items: center;
          cursor: pointer;
          position: relative;
        }
        .mini-arrow-wrapper {
          position: absolute;
          right: 0;
          top: 0;
          bottom: 0;
          width: 40px;
          border-left: 4px solid black;
          display: flex;
          align-items: center;
          justify-content: center;
        }
        .sort-option {
          padding: 10px 16px;
          font-weight: 900;
          font-size: 11px;
          border-bottom: 2px solid black;
          text-transform: uppercase;
          cursor: pointer;
        }
        .sort-option:last-child { border-bottom: none; }
        .sort-option:hover, .sort-option.active {
          background: #ADFF2F;
        }
      </style>

      <script>
        // Sort Dropdown Toggle
        const sortBtn = document.getElementById('sort-button');
        const sortOptions = document.getElementById('sort-options');
        const sortArrow = document.getElementById('sort-arrow');
        const sortVal = document.getElementById('sort-selected-value');

        sortBtn?.addEventListener('click', (e) => {
          e.stopPropagation();
          const isHidden = sortOptions?.classList.contains('hidden');
          if (isHidden) {
            sortOptions?.classList.remove('hidden');
            if (sortArrow) sortArrow.style.transform = 'rotate(180deg)';
          } else {
            sortOptions?.classList.add('hidden');
            if (sortArrow) sortArrow.style.transform = 'rotate(0deg)';
          }
        });

        document.querySelectorAll('.sort-option').forEach(opt => {
          opt.addEventListener('click', () => {
            if (sortVal) sortVal.innerText = opt.getAttribute('data-value') || '';
            sortOptions?.classList.add('hidden');
            if (sortArrow) sortArrow.style.transform = 'rotate(0deg)';
          });
        });

        document.addEventListener('click', () => {
          sortOptions?.classList.add('hidden');
          if (sortArrow) sortArrow.style.transform = 'rotate(0deg)';
        });
      </script>

      <!-- Regular Posts Grid (3 Columns) -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-20">
        {posts.slice(1, 7).map((post) => (
          <div class="blog-card">
            <img src={post.image} alt={post.title} class="blog-card-image" />
            <div class="blog-card-content">
              <span class={`blog-tag tag-${post.tags[0] === 'UX DESIGN' ? 'yellow' : 'green'}`}>
                {post.tags[0]}
              </span>
              <h3 class="blog-title">{post.title}</h3>
              <p class="blog-excerpt">{post.excerpt}</p>
            </div>
            <div class="blog-footer">
              <span>{post.date}</span>
              <span>{post.readTime}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Pagination -->
      <div class="flex justify-center items-center gap-6 mb-24">
        <button class="btn-neo btn-white px-6 py-2">
          <span class="font-black italic uppercase">Previous</span>
        </button>
        <div class="flex gap-3">
          <span class="w-12 h-12 flex items-center justify-center border-4 border-black bg-[#ADFF2F] font-black shadow-[4px_4px_0px_#000000]">1</span>
          <span class="w-12 h-12 flex items-center justify-center border-4 border-black bg-white font-black hover:bg-gray-100 cursor-pointer shadow-[4px_4px_0px_#000000]">2</span>
          <span class="w-12 h-12 flex items-center justify-center border-4 border-black bg-white font-black hover:bg-gray-100 cursor-pointer shadow-[4px_4px_0px_#000000]">3</span>
        </div>
        <button class="btn-neo btn-white px-6 py-2">
          <span class="font-black italic uppercase">Next</span>
        </button>
      </div>

    </div>
  </main>
</BaseLayout>
