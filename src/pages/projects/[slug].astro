                <div class="p-8 flex-grow flex flex-col">
                    <p class="text-lg font-medium leading-relaxed mb-8">{project.solution || "We implemented a strict Neobrutalist system that prioritizes data hierarchy and performance."}</p>
                    
                    <!-- Solution Points (The Controllers) -->
                    <ul class="space-y-3 mb-10 solution-points-list">
