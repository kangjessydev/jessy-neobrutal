<script lang="ts">
    function initSmartSlider(containerId: string, listSelector: string, activeClass: string) {
        const slider = document.getElementById(containerId);
        if (!slider) return;
        
        const listItems = document.querySelectorAll(listSelector);
        let currentIndex = 0;
        let interval: any;

        function goToSlide(index: number) {
            currentIndex = index;
            slider!.style.transform = `translateX(-${index * 100}%)`;
            
            listItems.forEach((item, i) => {
                if (i === index) {
                    item.classList.add(activeClass);
                } else {
                    item.classList.remove(activeClass);
                }
            });
        }

        function nextSlide() {
            goToSlide((currentIndex + 1) % listItems.length);
        }

        function startAutoSlide() {
            stopAutoSlide(); // Clear previous
            interval = setInterval(nextSlide, 4000);
        }

        function stopAutoSlide() {
            clearInterval(interval);
        }

        listItems.forEach((item, index) => {
            item.addEventListener('click', () => {
                stopAutoSlide();
                goToSlide(index);
                setTimeout(startAutoSlide, 8000); // Resume after manual click
            });
        });

        startAutoSlide();
    }

    // Initialize both sliders after content loads
    document.addEventListener('DOMContentLoaded', () => {
        initSmartSlider('problem-slider', '.problem-points-list li', 'active-point-prob');
        initSmartSlider('solution-slider', '.solution-points-list li', 'active-point-sol');
    });
</script>

<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    /* Custom Active States */
    .active-point-prob {
        background-color: #ff69b4 !important;
        color: white !important;
        transform: translateX(10px);
        box-shadow: -4px 0px 0px black;
    }
    .active-point-sol {
        background-color: #adff2f !important;
        color: black !important;
        transform: translateX(10px);
        box-shadow: -4px 0px 0px black;
    }
    
    .problem-points-list li, .solution-points-list li {
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .animate-marquee {
        animation: marquee 30s linear infinite;
    }
    .animate-marquee2 {
        animation: marquee2 30s linear infinite;
    }

    @keyframes marquee {
        0% { transform: translateX(0%); }
        100% { transform: translateX(-100%); }
    }

    @keyframes marquee2 {
        0% { transform: translateX(100%); }
        100% { transform: translateX(0%); }
    }
</style>
