    <!-- Technical Architecture (Floating Black Card) -->
    <section class="py-32 px-6 bg-[#f0f0f0]">
        <div class="max-w-7xl mx-auto">
            <div class="relative group">
                <!-- Shadow Layer -->
                <div class="absolute inset-0 bg-black translate-x-4 translate-y-4"></div>
                
                <!-- Main Card -->
                <div class="relative bg-black text-white p-12 lg:p-20 border-4 border-black">
