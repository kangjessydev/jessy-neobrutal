                    <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
                        
                        <!-- Frontend -->
                        <div class="flex flex-col gap-6">
                            <span class="material-symbols-outlined text-[#ffd700] text-4xl">grid_view</span>
                            <div>
                                <h4 class="font-lexend font-black text-2xl uppercase mb-4 tracking-tight">FRONTEND</h4>
