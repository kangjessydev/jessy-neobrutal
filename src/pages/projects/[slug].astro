---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjects } from '../../services/getProjects';

export function getStaticPaths() {
  const projects = getProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

if (!project) {
    return Astro.redirect('/404');
}
---

<BaseLayout title={`${project.title} | KANGJESSY DEV`}>
    
    <!-- Hero Section -->
    <section class="pt-32 pb-20 px-6 bg-white border-b-8 border-black">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
            
            <!-- Left: Info -->
            <div class="lg:col-span-2">
                <div class="inline-block bg-[#a5f624] text-black border-4 border-black px-4 py-2 mb-8 shadow-[4px_4px_0px_#000000] font-bold uppercase text-sm">
                    {project.category}
                </div>
                <h1 class="font-lexend font-black text-6xl md:text-8xl text-black uppercase mb-8 leading-[1.1] tracking-tighter">
                    {project.title}
                </h1>
                <p class="text-xl md:text-2xl text-[#5d5f5f] mb-10 max-w-2xl leading-relaxed">
                    {project.description}
                </p>

                <!-- Tech Stack Chips -->
                <div class="flex flex-wrap gap-3 mb-10">
                    {project.tech.map((tag) => (
                        <span class="border-2 border-black bg-white px-4 py-1 text-sm font-bold uppercase shadow-[2px_2px_0px_#000000]">
                            {tag}
                        </span>
                    ))}
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-wrap gap-6">
                    <a href={project.demoUrl} class="bg-[#ffd700] text-black border-4 border-black px-8 py-4 font-black uppercase tracking-wider shadow-[6px_6px_0px_#000000] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined">launch</span>
                        LIVE DEMO
                    </a>
                    <a href={project.githubUrl} class="bg-white text-black border-4 border-black px-8 py-4 font-black uppercase tracking-wider shadow-[6px_6px_0px_#000000] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined">code</span>
                        VIEW CODE
                    </a>
                </div>
            </div>

            <!-- Right: Specs Card (Sticky) -->
            <div class="lg:sticky lg:top-32 lg:col-span-1">
                <div class="border-4 border-black bg-white p-8 shadow-[12px_12px_0px_#000000]">
                    <h3 class="font-lexend font-black text-2xl uppercase mb-6 border-b-4 border-black pb-4">SPECS</h3>
                    
                    <div class="space-y-6">
                        <div>
                            <span class="block text-xs font-bold uppercase text-[#7e775f] mb-1 tracking-widest">Year</span>
                            <span class="text-2xl font-black uppercase">{project.year || "2024"}</span>
                        </div>
                        <div>
                            <span class="block text-xs font-bold uppercase text-[#7e775f] mb-1 tracking-widest">Role</span>
                            <span class="text-2xl font-black uppercase">{project.role || "Lead Developer"}</span>
                        </div>
                        <div>
                            <span class="block text-xs font-bold uppercase text-[#7e775f] mb-1 tracking-widest">Client</span>
                            <span class="text-2xl font-black uppercase">{project.client || "External Project"}</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- Marquee -->
    <div class="bg-[#ffd700] border-b-8 border-black py-4 overflow-hidden whitespace-nowrap flex select-none">
        <div class="animate-marquee flex gap-8 items-center min-w-full">
            {[...Array(10)].map(() => (
                <div class="flex gap-8 items-center">
                    <span class="font-lexend font-black text-2xl uppercase italic">DESIGN WITH PURPOSE</span>
                    <span class="material-symbols-outlined text-4xl">star</span>
                    <span class="font-lexend font-black text-2xl uppercase italic">RAW LOGIC ONLY</span>
                    <span class="material-symbols-outlined text-4xl">bolt</span>
                    <span class="font-lexend font-black text-2xl uppercase italic">NEOBRUTAL SYSTEM</span>
                    <span class="material-symbols-outlined text-4xl">change_history</span>
                </div>
            ))}
        </div>
        <div class="animate-marquee2 flex gap-8 items-center min-w-full absolute">
            {[...Array(10)].map(() => (
                <div class="flex gap-8 items-center">
                    <span class="font-lexend font-black text-2xl uppercase italic">DESIGN WITH PURPOSE</span>
                    <span class="material-symbols-outlined text-4xl">star</span>
                    <span class="font-lexend font-black text-2xl uppercase italic">RAW LOGIC ONLY</span>
