            </div>

            <!-- THE SOLUTION CARD -->
            <div class="border-4 border-black bg-white shadow-[8px_8px_0px_#000000] flex flex-col h-full">
                <div class="bg-[#adff2f] text-black border-b-4 border-black px-6 py-3 font-black uppercase text-sm tracking-widest">
                    THE SOLUTION
