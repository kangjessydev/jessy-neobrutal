---
const { pathname } = Astro.url;
import Button from './Button.astro';

const mainLinks = [
    { label: 'Home', href: '/' },
    { label: 'About', href: '/about' },
    { label: 'Projects', href: '/projects' },
    { label: 'Blog', href: '/blog' },
    { label: 'Products', href: '/products' },
];

const moreLinks = [
    { label: 'Bio Link', href: '/bio' },
];

function isActive(href: string) {
    if (href === '/') return pathname === '/';
    return pathname.startsWith(href);
}
---

<header class="bg-white border-b-8 border-black flex justify-between items-center w-full px-8 py-6 sticky top-0 z-[100]">
    <!-- Logo & Network Switcher -->
    <div class="flex items-center gap-2">
        <a href="/" class="text-2xl font-black bg-[#FFD700] text-black px-4 py-1 border-4 border-black shadow-[4px_4px_0px_#000000] font-lexend uppercase tracking-tighter hover:translate-y-1 hover:shadow-none transition-all">
            KANGJESSY_DEV
        </a>
        
        <!-- Network Dropdown Trigger -->
        <div class="relative" id="network-menu">
            <button
                id="network-btn"
                class="bg-black text-white w-8 h-8 flex items-center justify-center border-4 border-black shadow-[3px_3px_0px_#FFD700] hover:translate-y-0.5 hover:shadow-none transition-all"
                title="Our Network"
            >
                <span id="network-arrow" class="transition-transform duration-200 text-xl font-black">▾</span>
            </button>

            <!-- Network Dropdown Content -->
            <div
                id="network-dropdown"
                class="absolute top-[calc(100%+12px)] left-0 bg-white border-4 border-black shadow-[8px_8px_0px_#000000] min-w-[220px] hidden z-50 origin-top-left"
            >
                <div class="bg-black text-white px-4 py-2 text-[10px] font-black uppercase tracking-widest border-b-4 border-black">
                    Connected Networks
                </div>
                <a
                    href="https://mejadaring.id"
                    target="_blank"
                    class="block px-6 py-4 font-lexend font-black uppercase text-xs tracking-tighter text-black hover:bg-[#ADFF2F] border-b-4 border-black transition-colors"
                >
                    mejadaring.id <span class="material-symbols-outlined text-xs align-middle">open_in_new</span>
                </a>
                <a
                    href="https://skincluv.id"
                    target="_blank"
                    class="block px-6 py-4 font-lexend font-black uppercase text-xs tracking-tighter text-black hover:bg-[#ADFF2F] transition-colors"
                >
                    skincluv.id <span class="material-symbols-outlined text-xs align-middle">open_in_new</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Main Nav (Slimming down) -->
    <div class="flex items-center gap-4">
        <!-- Language Switcher (Slim Pill Style) -->
        <div class="hidden sm:flex border-4 border-black bg-black p-1 shadow-[3px_3px_0px_#000000] overflow-hidden">
            <button class="px-3 py-1 text-[10px] font-black uppercase text-white hover:bg-[#ADFF2F] hover:text-black transition-colors bg-[#ADFF2F] !text-black">ID</button>
            <button class="px-3 py-1 text-[10px] font-black uppercase text-white hover:bg-[#ADFF2F] hover:text-black transition-colors">EN</button>
        </div>

        <!-- Menu Toggle Button -->
        <button
            id="menu-toggle"
            class="bg-[#FFD700] text-black border-4 border-black px-4 py-1 font-lexend font-black uppercase tracking-tighter shadow-[4px_4px_0px_#000000] hover:translate-y-1 hover:shadow-none transition-all flex items-center gap-2"
        >
            MENU <span class="text-xl">☰</span>
        </button>
    </div>
</header>

<!-- Full Screen Overlay Menu -->
<div id="full-menu" class="fixed inset-0 bg-white z-[200] hidden flex-col border-[12px] border-black">
    <div class="flex justify-between items-center p-8 border-b-8 border-black bg-[#ADFF2F]">
        <span class="font-lexend font-black uppercase text-2xl tracking-tighter">NAVIGATION</span>
        <button id="menu-close" class="bg-black text-white w-12 h-12 flex items-center justify-center border-4 border-black shadow-[4px_4px_0px_#000000] hover:translate-y-1 hover:shadow-none transition-all text-2xl font-black">✕</button>
    </div>
    
    <div class="flex-grow flex flex-col md:flex-row divide-y-8 md:divide-y-0 md:divide-x-8 divide-black overflow-y-auto">
        <!-- Main Links (Left Side) -->
        <div id="main-links-container" class="flex-grow p-12 flex flex-col justify-center gap-6">
            <a href="/" class:list={["menu-link-dynamic font-lexend font-black text-4xl md:text-7xl uppercase tracking-tighter text-black hover:italic hover:translate-x-4 transition-all inline-block", isActive('/') && "italic underline underline-offset-8 decoration-8 decoration-[#ADFF2F] translate-x-4"]} data-target="default">Home</a>
            <a href="/about" class:list={["menu-link-dynamic font-lexend font-black text-4xl md:text-7xl uppercase tracking-tighter text-black hover:italic hover:translate-x-4 transition-all inline-block", isActive('/about') && "italic underline underline-offset-8 decoration-8 decoration-[#ADFF2F] translate-x-4"]} data-target="default">About</a>
            <a href="/projects" class:list={["menu-link-dynamic font-lexend font-black text-4xl md:text-7xl uppercase tracking-tighter text-black hover:italic hover:translate-x-4 transition-all inline-block", isActive('/projects') && "italic underline underline-offset-8 decoration-8 decoration-[#ADFF2F] translate-x-4"]} data-target="projects">Projects</a>
            <a href="/blog" class:list={["menu-link-dynamic font-lexend font-black text-4xl md:text-7xl uppercase tracking-tighter text-black hover:italic hover:translate-x-4 transition-all inline-block", isActive('/blog') && "italic underline underline-offset-8 decoration-8 decoration-[#ADFF2F] translate-x-4"]} data-target="default">Blog</a>
            
            <button class="menu-link-dynamic text-left font-lexend font-black text-4xl md:text-7xl uppercase tracking-tighter text-black hover:italic hover:translate-x-4 transition-all inline-block focus:outline-none" data-target="network">
                Network
            </button>
        </div>

        <!-- Dynamic Sidebar Panel -->
        <div id="dynamic-side-panel" class="w-full md:w-[450px] bg-[#f0f0f0] hidden md:flex flex-col flex-grow md:flex-grow-0 transition-all duration-300 border-l-0 md:border-l-8 border-black overflow-hidden relative">
            
            <!-- Default Content -->
            <div id="content-default" class="side-content flex flex-col justify-between h-full p-12">
                <div>
                    <h4 class="font-black uppercase text-sm tracking-widest mb-12 py-1 px-4 bg-black text-white inline-block">CONNECT</h4>
                    <div class="flex flex-col gap-6">
                        <a href="#" class="text-3xl font-black uppercase hover:text-[#ADFF2F] transition-colors flex items-center gap-4 group">
                            LinkedIn <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-all -translate-x-2 group-hover:translate-x-0">arrow_outward</span>
                        </a>
                        <a href="#" class="text-3xl font-black uppercase hover:text-[#ADFF2F] transition-colors flex items-center gap-4 group">
                            Github <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-all -translate-x-2 group-hover:translate-x-0">arrow_outward</span>
                        </a>
                        <a href="#" class="text-3xl font-black uppercase hover:text-[#FFD700] transition-colors flex items-center gap-4 group">
                            Twitter <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-all -translate-x-2 group-hover:translate-x-0">arrow_outward</span>
                        </a>
                    </div>
                </div>
                <div class="mt-20">
                    <Button href="/contact" variant="yellow" size="lg" class="w-full text-center">Get In Touch</Button>
                </div>
            </div>

            <!-- Network Submenu Content -->
            <div id="content-network" class="side-content hidden flex-col h-full bg-[#ADFF2F] p-12">
                <button class="back-to-menu md:hidden mb-8 font-black uppercase text-xs flex items-center gap-2 underline">← Back to Menu</button>
                <h4 class="font-black uppercase text-sm tracking-widest mb-12 py-1 px-4 bg-black text-white inline-block">EXPLORE NETWORK</h4>
                <div class="flex flex-col gap-8">
                    <a href="https://mejadaring.id" target="_blank" class="block group">
                        <span class="text-xs font-bold text-black/60 block mb-1">Education Portal</span>
                        <span class="text-4xl font-lexend font-black uppercase hover:translate-x-2 transition-transform block">MEJADARING.ID</span>
                    </a>
                    <a href="https://skincluv.id" target="_blank" class="block group">
                        <span class="text-xs font-bold text-black/60 block mb-1">Skincare Analytics</span>
                        <span class="text-4xl font-lexend font-black uppercase hover:translate-x-2 transition-transform block">SKINCLUV.ID</span>
                    </a>
                </div>
            </div>

            <!-- Projects Submenu Content -->
            <div id="content-projects" class="side-content hidden flex-col h-full bg-[#FFD700] p-12">
                <button class="back-to-menu md:hidden mb-8 font-black uppercase text-xs flex items-center gap-2 underline">← Back to Menu</button>
                <h4 class="font-black uppercase text-sm tracking-widest mb-12 py-1 px-4 bg-black text-white inline-block">PORTFOLIO</h4>
                <div class="flex flex-col gap-6">
                    <a href="/projects" class="text-3xl font-black uppercase hover:translate-x-2 transition-transform block">Web Development</a>
                    <a href="/projects" class="text-3xl font-black uppercase hover:translate-x-2 transition-transform block">Mobile apps</a>
                    <a href="/projects" class="text-3xl font-black uppercase hover:translate-x-2 transition-transform block">UI/UX Design</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .side-content {
        animation: sideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes sideIn {
        from { opacity: 0; transform: translateX(30px); }
        to { opacity: 1; transform: translateX(0); }
    }

    .side-content.leaving {
        animation: sideOut 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes sideOut {
        from { opacity: 1; transform: translateX(0); }
        to { opacity: 0; transform: translateX(50px); }
    }

    #main-links-container.entering {
        animation: mainIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes mainIn {
        from { opacity: 0; transform: translateX(-30px); }
        to { opacity: 1; transform: translateX(0); }
    }

    #full-menu .menu-link-dynamic {
        opacity: 0;
        transform: translateY(40px);
        transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    #full-menu.flex .menu-link-dynamic {
        opacity: 1;
        transform: translateY(0);
    }

    #full-menu.flex .menu-link-dynamic:nth-child(1) { transition-delay: 0.1s; }
    #full-menu.flex .menu-link-dynamic:nth-child(2) { transition-delay: 0.15s; }
    #full-menu.flex .menu-link-dynamic:nth-child(3) { transition-delay: 0.2s; }
    #full-menu.flex .menu-link-dynamic:nth-child(4) { transition-delay: 0.25s; }
    #full-menu.flex .menu-link-dynamic:nth-child(5) { transition-delay: 0.3s; }

    #full-menu {
        transform: translateX(100%);
        transition: transform 0.5s cubic-bezier(0.8, 0, 0.2, 1);
    }
    #full-menu.flex {
        transform: translateX(0);
    }
</style>

<script>
    const menuToggle = document.getElementById('menu-toggle');
    const menuClose = document.getElementById('menu-close');
    const fullMenu = document.getElementById('full-menu');
    const mainLinksContainer = document.getElementById('main-links-container');
    const dynamicSidePanel = document.getElementById('dynamic-side-panel');
    const sideContents = document.querySelectorAll('.side-content');
    const backBtn = document.querySelectorAll('.back-to-menu');

    const networkBtn = document.getElementById('network-btn');
    const networkDropdown = document.getElementById('network-dropdown');
    const networkArrow = document.getElementById('network-arrow');

    function closeAllMenus() {
        networkDropdown?.classList.add('hidden');
        if (networkArrow) networkArrow.style.transform = 'rotate(0deg)';
    }

    // Navigation Switch Logic
    const menuLinks = document.querySelectorAll('.menu-link-dynamic');
    
    menuLinks.forEach(link => {
        const target = link.getAttribute('data-target');
        
        const showPanel = (e) => {
            const isMobile = window.innerWidth < 768;
            const hasSubmenu = target !== 'default';
            
            // Only swap on hover for desktop, or click for mobile
            if (e.type === 'mouseenter' && isMobile) return;

            // FIX: Prevent navigation on mobile if it has a submenu
            if (e.type === 'click' && isMobile && hasSubmenu) {
                e.preventDefault();
            }

            sideContents.forEach(content => {
                content.classList.add('hidden');
                content.classList.remove('leaving');
            });
            const targetEl = document.getElementById(`content-${target}`);
            
            if (targetEl) {
                targetEl.classList.remove('hidden');
                targetEl.classList.add('flex');
            }

            if (isMobile && hasSubmenu) {
                mainLinksContainer?.classList.add('hidden');
                mainLinksContainer?.classList.remove('entering');
                dynamicSidePanel?.classList.remove('hidden');
                dynamicSidePanel?.classList.add('flex');
            }
        };

        link.addEventListener('mouseenter', showPanel);
        link.addEventListener('click', showPanel); 
    });

    // Back to Menu Logic (Mobile with Animation)
    backBtn.forEach(btn => {
        btn.addEventListener('click', () => {
            const currentContent = document.querySelector('.side-content:not(.hidden)');
            currentContent?.classList.add('leaving');

            setTimeout(() => {
                mainLinksContainer?.classList.remove('hidden');
                mainLinksContainer?.classList.add('entering');
                dynamicSidePanel?.classList.add('hidden');
                dynamicSidePanel?.classList.remove('flex');
                currentContent?.classList.add('hidden');
                currentContent?.classList.remove('leaving');
            }, 250);
        });
    });

    // Reset view when closing the whole menu
    const resetMenuView = () => {
        mainLinksContainer?.classList.remove('hidden');
        mainLinksContainer?.classList.remove('entering');
        if (window.innerWidth < 768) {
            dynamicSidePanel?.classList.add('hidden');
            dynamicSidePanel?.classList.remove('flex');
        }
    };

    menuToggle?.addEventListener('click', () => {
        resetMenuView();
        fullMenu?.classList.remove('hidden');
        setTimeout(() => {
            fullMenu?.classList.add('flex');
            document.body.style.overflow = 'hidden';
        }, 10);
    });

    menuClose?.addEventListener('click', () => {
        fullMenu?.classList.remove('flex');
        document.body.style.overflow = '';
        setTimeout(() => {
            fullMenu?.classList.add('hidden');
        }, 500);
    });

    networkBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isHidden = networkDropdown?.classList.contains('hidden');
        closeAllMenus();
        if (isHidden) {
            networkDropdown?.classList.remove('hidden');
            if (networkArrow) networkArrow.style.transform = 'rotate(180deg)';
        }
    });

    document.addEventListener('click', () => {
        closeAllMenus();
    });
</script>
