---
const { pathname } = Astro.url;
import Button from './Button.astro';

const mainLinks = [
    { label: 'Home', href: '/' },
    { label: 'About', href: '/about' },
    { label: 'Projects', href: '/projects' },
    { label: 'Blog', href: '/blog' },
    { label: 'Products', href: '/products' },
];

const moreLinks = [
    { label: 'Bio Link', href: '/bio' },
];

function isActive(href: string) {
    if (href === '/') return pathname === '/';
    return pathname.startsWith(href);
}
---

<header class="bg-white border-b-8 border-black flex justify-between items-center w-full px-8 py-6 sticky top-0 z-[100]">
    <!-- Logo & Network Switcher -->
    <div class="flex items-center gap-2">
        <a href="/" class="text-2xl font-black bg-[#FFD700] text-black px-4 py-1 border-4 border-black shadow-[4px_4px_0px_#000000] font-lexend uppercase tracking-tighter hover:translate-y-1 hover:shadow-none transition-all">
            KANGJESSY_DEV
        </a>
        
        <!-- Network Dropdown Trigger -->
        <div class="relative" id="network-menu">
            <button
                id="network-btn"
                class="bg-black text-white w-8 h-8 flex items-center justify-center border-4 border-black shadow-[3px_3px_0px_#FFD700] hover:translate-y-0.5 hover:shadow-none transition-all"
                title="Our Network"
            >
                <span id="network-arrow" class="transition-transform duration-200 text-xl font-black">▾</span>
            </button>

            <!-- Network Dropdown Content -->
            <div
                id="network-dropdown"
                class="absolute top-[calc(100%+12px)] left-0 bg-white border-4 border-black shadow-[8px_8px_0px_#000000] min-w-[220px] hidden z-50 origin-top-left"
            >
                <div class="bg-black text-white px-4 py-2 text-[10px] font-black uppercase tracking-widest border-b-4 border-black">
                    Connected Networks
                </div>
                <a
                    href="https://mejadaring.id"
                    target="_blank"
                    class="block px-6 py-4 font-lexend font-black uppercase text-xs tracking-tighter text-black hover:bg-[#ADFF2F] border-b-4 border-black transition-colors"
                >
                    mejadaring.id <span class="material-symbols-outlined text-xs align-middle">open_in_new</span>
                </a>
                <a
                    href="https://skincluv.id"
                    target="_blank"
                    class="block px-6 py-4 font-lexend font-black uppercase text-xs tracking-tighter text-black hover:bg-[#ADFF2F] transition-colors"
                >
                    skincluv.id <span class="material-symbols-outlined text-xs align-middle">open_in_new</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Main Nav -->
    <nav class="hidden md:flex gap-6 items-center">
        {mainLinks.map(link => (
            <a
                href={link.href}
                class={`font-lexend font-black uppercase tracking-tighter text-black hover:bg-[#FFD700] transition-colors px-2 py-1 ${isActive(link.href) ? 'bg-[#FFD700] underline decoration-4 underline-offset-4' : ''}`}
            >
                {link.label}
            </a>
        ))}

        <!-- More Dropdown -->
        <div class="relative" id="more-menu">
            <button
                id="more-btn"
                class="font-lexend font-black uppercase tracking-tighter text-black hover:bg-[#FFD700] transition-colors px-2 py-1 flex items-center gap-1"
            >
                More <span id="more-arrow" class="transition-transform duration-200">▾</span>
            </button>

            <!-- Dropdown -->
            <div
                id="more-dropdown"
                class="absolute top-[calc(100%+12px)] right-0 bg-white border-4 border-black shadow-[8px_8px_0px_#000000] min-w-[180px] hidden z-50 origin-top"
            >
                {moreLinks.map(link => (
                    <a
                        href={link.href}
                        class={`block px-6 py-4 font-lexend font-black uppercase text-sm tracking-tighter text-black hover:bg-[#FFD700] border-b-4 border-black last:border-b-0 transition-colors ${isActive(link.href) ? 'bg-[#FFD700]' : ''}`}
                    >
                        {link.label}
                    </a>
                ))}
            </div>
        </div>
    </nav>

    <!-- CTA Button -->
    <div class="hidden md:block">
        <Button href="/contact" variant="yellow" size="md">
            Let's Talk
        </Button>
    </div>

    <!-- Mobile Hamburger -->
    <button id="mobile-menu-btn" class="md:hidden border-4 border-black p-2 shadow-[4px_4px_0px_#000000] font-black">
        ☰
    </button>
</header>

<!-- Mobile Nav -->
<div id="mobile-nav" class="hidden md:hidden bg-white border-b-8 border-black">
    {[...mainLinks, ...moreLinks].map(link => (
        <a
            href={link.href}
            class={`block px-8 py-4 font-lexend font-black uppercase tracking-tighter text-black border-b-4 border-black hover:bg-[#FFD700] transition-colors ${isActive(link.href) ? 'bg-[#FFD700]' : ''}`}
        >
            {link.label}
        </a>
    ))}
</div>

<script>
    const networkBtn = document.getElementById('network-btn');
    const networkDropdown = document.getElementById('network-dropdown');
    const networkArrow = document.getElementById('network-arrow');

    const moreBtn = document.getElementById('more-btn');
    const moreDropdown = document.getElementById('more-dropdown');
    const moreArrow = document.getElementById('more-arrow');

    function closeAllMenus() {
        // Close Network Menu
        networkDropdown?.classList.add('hidden');
        if (networkArrow) networkArrow.style.transform = 'rotate(0deg)';
        
        // Close More Menu
        moreDropdown?.classList.add('hidden');
        if (moreArrow) moreArrow.style.transform = 'rotate(0deg)';
    }

    // Toggle Network Menu
    networkBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isHidden = networkDropdown?.classList.contains('hidden');
        closeAllMenus();
        if (isHidden) {
            networkDropdown?.classList.remove('hidden');
            if (networkArrow) networkArrow.style.transform = 'rotate(180deg)';
        }
    });

    // Toggle More Menu
    moreBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isHidden = moreDropdown?.classList.contains('hidden');
        closeAllMenus();
        if (isHidden) {
            moreDropdown?.classList.remove('hidden');
            if (moreArrow) moreArrow.style.transform = 'rotate(180deg)';
        }
    });

    // Click Away Listener
    document.addEventListener('click', () => {
        closeAllMenus();
    });

    // Mobile menu
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileNav = document.getElementById('mobile-nav');

    mobileBtn?.addEventListener('click', () => {
        mobileNav?.classList.toggle('hidden');
    });
</script>
