---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingChat from '../components/FloatingChat.astro';
const { 
    title = "KANGJESSY DEV - Portfolio", 
    hideNav = false, 
    hideFooter = false 
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="light scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;700;800;900&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</head>
<body class="bg-[#f9f9f9] text-[#1b1b1b] font-body-md overflow-x-hidden m-0 p-0">
    {!hideNav && <Navbar />}
    
    <main>
        <slot />
    </main>

    {!hideFooter && <Footer />}
    <FloatingChat />
</body>
</html>
